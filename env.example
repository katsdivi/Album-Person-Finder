# Postgres connection string from your Supabase project
# Settings -> Database -> Connection string -> URI
# (Use the "session" pooler string if you're on the free tier)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres

# Path to the OAuth client file you download from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# Where the cached Drive login token gets stored after first auth
GOOGLE_TOKEN_PATH=token.json

# The Drive folder ID to start walking from (right-click folder -> Share -> Copy link,
# the long string after /folders/ in the URL). Point this at your top-level family
# photos folder, e.g. the "Akshay & Shreya" folder or its parent.
DRIVE_ROOT_FOLDER_ID=1My4hb0f8XQnmKK3S3BMLS5EF3msnPGYW

# Minimum cosine similarity (0-1) for a face to count as a "match" in search.
# Start around 0.45-0.55 and tune based on real results.
MATCH_THRESHOLD=0.5
